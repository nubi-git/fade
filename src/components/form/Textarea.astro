---
interface Props {
  label: string;
  name: string;
  value?: string | null;
  error?: string;
  hint?: string;
  required?: boolean;
  rows?: number;
  placeholder?: string;
}
const { label, name, value = "", error, hint, required = false, rows = 4, placeholder } = Astro.props;
const id = `f-${name}`;
const errId = `${id}-error`;
const hintId = `${id}-hint`;
const describedBy = [error ? errId : null, hint ? hintId : null].filter(Boolean).join(" ") || undefined;
---

<div class="field" data-field>
  <label for={id} class="field-label">
    {label}{required && <span class="text-red-600" aria-hidden="true"> *</span>}
  </label>
  <textarea
    id={id}
    name={name}
    rows={rows}
    class="field-control resize-y"
    required={required}
    placeholder={placeholder}
    aria-invalid={error ? "true" : undefined}
    aria-describedby={describedBy}
    aria-errormessage={error ? errId : undefined}
  >{value ?? ""}</textarea>
  {hint && <p id={hintId} class="field-hint">{hint}</p>}
  {error && <p id={errId} class="field-error" role="alert">{error}</p>}
</div>
