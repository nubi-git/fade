---
import FormSection from "../form/FormSection.astro";
import TextInput from "../form/TextInput.astro";
import Textarea from "../form/Textarea.astro";
import Checkbox from "../form/Checkbox.astro";
import FileInput from "../form/FileInput.astro";
import SubmitButton from "../form/SubmitButton.astro";
import FormEnhancer from "../form/FormEnhancer.astro";
import type { FieldErrors } from "../../lib/validation";

export interface ProjectValues {
  name: string;
  type: string;
  year: string | number | null;
  location: string | null;
  client: string | null;
  direction: string | null;
  summary: string | null;
  description: string | null;
  published: boolean;
  sortOrder: string | number;
}

interface Props {
  values: ProjectValues;
  errors?: FieldErrors;
  coverImage?: string | null;
  isEdit?: boolean;
  draftKey?: string;
}
const { values, errors = {}, coverImage = null, isEdit = false, draftKey } = Astro.props;
const formError = errors._form;
---

<form method="POST" enctype="multipart/form-data" data-enhanced data-draft={draftKey} class="space-y-8" novalidate>
  {formError && (
    <p class="rounded-md bg-red-50 px-3 py-2 text-sm font-medium text-red-700" role="alert">{formError}</p>
  )}

  <FormSection title="Datos del proyecto" cols={2}>
    <TextInput label="Nombre" name="name" value={values.name} error={errors.name} required />
    <TextInput label="Tipo" name="type" value={values.type} error={errors.type} required placeholder="Instalación sanitaria" />
    <TextInput label="Año de ejecución" name="year" type="number" min={1900} max={2100} value={values.year} error={errors.year} />
    <TextInput label="Ubicación" name="location" value={values.location} error={errors.location} />
    <TextInput label="Comitente" name="client" value={values.client} error={errors.client} />
    <TextInput label="Dirección de obra" name="direction" value={values.direction} error={errors.direction} />
  </FormSection>

  <FormSection title="Detalle" description="Textos que se muestran en la página pública del proyecto.">
    <Textarea label="Resumen" name="summary" rows={2} value={values.summary} error={errors.summary} hint="Línea breve que aparece debajo del título." />
    <Textarea label="Desarrollo realizado" name="description" rows={5} value={values.description} error={errors.description} />
  </FormSection>

  <FormSection title="Portada y publicación" cols={2}>
    <FileInput label="Imagen de portada" name="cover" accept="image/*" hint="Se usa como miniatura en el listado.">
      {coverImage && <img src={coverImage} alt="Portada actual" class="mt-3 h-24 w-36 rounded-lg object-cover ring-1 ring-line" />}
    </FileInput>
    <TextInput label="Orden" name="sortOrder" type="number" value={values.sortOrder} error={errors.sortOrder} hint="Mayor número aparece primero." />
  </FormSection>

  <Checkbox label="Publicado" name="published" checked={values.published} hint="Si está desmarcado, queda como borrador y no se muestra en la web." />

  <div class="flex flex-wrap items-center gap-4 border-t border-line pt-6">
    <SubmitButton label="Guardar proyecto" />
    <a href="/admin/projects" class="text-sm font-medium text-body transition-colors hover:text-ink">Cancelar</a>
    {isEdit && (
      <button
        type="submit"
        name="_action"
        value="delete"
        formnovalidate
        class="ml-auto rounded-md px-3 py-2 text-sm font-medium text-red-600 transition-colors hover:bg-red-50"
        data-confirm="Se eliminará el proyecto junto con sus imágenes. Esta acción no se puede deshacer."
        data-confirm-title="Eliminar proyecto"
      >
        Eliminar proyecto
      </button>
    )}
  </div>

  <FormEnhancer />
</form>
