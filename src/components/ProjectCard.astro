---
interface Props {
  img: string;
  type: string;
  name: string;
  year: string | number;
  href?: string;
}
const { img, type, name, year, href = "/proyectos" } = Astro.props;
---

<a href={href} class="group relative block aspect-[4/3] overflow-hidden rounded-xl">
  <img src={img} alt={name} class="h-full w-full object-cover" loading="lazy" />

  <!-- Pestaña inferior que se despliega en hover -->
  <div
    class="absolute inset-x-0 bottom-0 translate-y-full bg-white/80 p-5 backdrop-blur-sm transition-transform duration-300 ease-out group-hover:translate-y-0"
  >
    <span class="inline-block rounded-md bg-accent px-3 py-1 text-xs font-semibold text-white">
      {type}
    </span>
    <h3 class="mt-3 text-lg font-extrabold uppercase tracking-tight text-ink">{name}</h3>
    <p class="text-body">{year}</p>
  </div>
</a>
