---
import { Image } from "astro:assets";
import logoDark from "../assets/logos/logo_fade.png";
import logoLight from "../assets/logos/logo_fade_blanco.png";

interface Props {
  variant?: "dark" | "light";
  class?: string;
  imgClass?: string;
}
const { variant = "dark", class: className = "", imgClass = "h-11" } = Astro.props;
const src = variant === "light" ? logoLight : logoDark;
---

<a href="/" class={`inline-flex items-center ${className}`} aria-label="FADE Ingeniería - inicio">
  <Image src={src} alt="FADE Ingeniería" format="webp" class={`w-auto ${imgClass}`} />
</a>
