---
import OptImage from "./OptImage.astro";

interface Props {
  variant?: "dark" | "light";
  class?: string;
  imgClass?: string;
}
const { variant = "dark", class: className = "", imgClass = "h-11" } = Astro.props;
const isLight = variant === "light";
const name = isLight ? "logo-fade-blanco" : "logo-fade";
const w = isLight ? 252 : 200;
const h = isLight ? 123 : 74;
---

<a href="/" class={`inline-flex items-center ${className}`} aria-label="FADE Ingeniería - inicio">
  <OptImage name={name} widths={[w]} width={w} height={h} sizes={`${w}px`} alt="FADE Ingeniería" class={`w-auto ${imgClass}`} />
</a>
