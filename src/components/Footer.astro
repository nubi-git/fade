---
import Logo from './Logo.astro'

const nav = [
  { label: 'Home', href: '/' },
  { label: 'Nosotros', href: '/nosotros' },
  { label: 'Servicios', href: '/servicios' },
  { label: 'Obras y proyectos', href: '/proyectos' },
  { label: 'Contacto', href: '/contacto' },
]
---

<footer class="bg-brand-light text-white">
  <div
    class="mx-auto flex max-w-7xl flex-col gap-8 px-6 py-12 md:flex-row md:items-center md:justify-between"
  >
    <Logo variant="light" imgClass="h-20" />
    <nav aria-label="Footer">
      <ul class="flex flex-wrap gap-6 text-sm">
        {
          nav.map((item) => (
            <li>
              <a href={item.href} class="text-white/90 underline-offset-4 hover:underline">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <div class="bg-footer-bar">
    <div
      class="mx-auto flex max-w-7xl flex-col items-center gap-3 px-6 py-4 text-center text-xs text-white/70 sm:flex-row sm:justify-between sm:text-left"
    >
      <p>&copy; {new Date().getFullYear()} FADE Ingeniería. Todos los derechos reservados.</p>
      <div class="flex items-center gap-4">
        <a href="#" aria-label="Facebook" class="hover:text-white">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H9v3h2v6h3v-6h2.5l.5-3H14V9.5c0-.3.2-.5.5-.5H14z"
            ></path></svg
          >
        </a>
        <a href="#" aria-label="Instagram" class="hover:text-white">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="4"
            ></circle><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"
            ></circle></svg
          >
        </a>
      </div>
    </div>
  </div>
</footer>
