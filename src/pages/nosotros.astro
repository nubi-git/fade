---
import Layout from "../layouts/Layout.astro";
import ContactCta from "../components/ContactCta.astro";
import { Image, getImage } from "astro:assets";
import nosotrosHero from "../assets/fondos/nosotros_hero_image.png";
import testimonialsImg from "../assets/fondos/testimonials_image.png";
import { db } from "../lib/db";
import { logos } from "../lib/db/schema";
import { eq, asc } from "drizzle-orm";

// Hero (LCP): preload en WebP.
const heroWidth = 1600;
const heroPreload = await getImage({ src: nosotrosHero, width: heroWidth, format: "webp" });

const rows = await db
  .select()
  .from(logos)
  .where(eq(logos.kind, "cliente"))
  .orderBy(asc(logos.sortOrder), asc(logos.createdAt))
  .catch(() => []);
const clients = rows.map((l) => l.imageUrl);

// Dos filas para el carousel (mitad arriba, mitad abajo)
const half = Math.ceil(clients.length / 2);
const rowTop = clients.slice(0, half);
const rowBottom = clients.slice(half);
---

<Layout title="Nosotros — FADE Ingeniería">
  <link slot="head" rel="preload" as="image" href={heroPreload.src} fetchpriority="high" />

  <!-- Hero -->
  <section class="relative isolate flex min-h-[540px] sm:min-h-[700px] items-center overflow-hidden text-white">
    <Image src={nosotrosHero} alt="" width={heroWidth} format="webp" loading="eager" fetchpriority="high" data-parallax="0.1" class="absolute -top-[10%] left-0 -z-20 h-[120%] w-full object-cover" />
    <div class="absolute inset-0 -z-10 bg-gradient-to-br from-brand-dark/85 via-ink/80 to-black/80"></div>
    <div class="mx-auto w-full max-w-7xl px-6 lg:px-10" data-reveal-group data-reveal-stagger="120">
      <h1 class="max-w-3xl text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        Desde el proyecto hasta la ejecución, con excelencia
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-white/80">
        Nuestra empresa se construye a partir del compromiso, la evolución constante y una mirada
        integral del trabajo. A lo largo del tiempo, hemos consolidado una identidad basada en el
        profesionalismo, la solidez técnica y la capacidad de adaptarnos a las demandas de cada
        contexto.
      </p>
    </div>
  </section>

  <!-- Nuestra historia -->
  <section class="mx-auto max-w-7xl px-6 py-20 lg:px-10">
    <p class="text-sm font-semibold uppercase tracking-widest text-accent" data-reveal="fade-up">+2 décadas de experiencia</p>
    <h2 class="mt-2 text-3xl font-extrabold text-ink sm:text-4xl" data-reveal="fade-up" data-reveal-delay="80">Nuestra historia</h2>
    <div class="mt-6 space-y-5 text-body lg:columns-2 lg:gap-12 lg:space-y-0 [&>p]:mb-5 [&>p]:break-inside-avoid" data-reveal="fade-in" data-reveal-delay="160">
      <p>
        FADE Ingeniería nació a partir de la trayectoria de sus socios fundadores, con más de 30
        años de experiencia en la construcción. Hoy, con más de 20 años de desarrollo, es una
        empresa de referencia en Ingeniería Sanitaria, Gas e Incendio, respaldada por un equipo de
        profesionales especializados.
      </p>
      <p>
        Desarrolla, asesora y ejecuta proyectos de instalaciones sanitarias, gas, incendio, riego,
        natatorios y aire comprimido, acompañando cada obra desde su inicio hasta su finalización,
        con soluciones eficientes, confiables e innovadoras.
      </p>
      <p>
        Cuenta con un equipo técnico altamente capacitado, operarios especializados, unidades
        móviles, galpón logístico y una oficina técnico-administrativa dedicada al asesoramiento
        integral, ofreciendo calidad, optimización de recursos y resultados que garantizan
        tranquilidad en cada proyecto.
      </p>
    </div>
  </section>

  <!-- FADE en los medios (igual que en Home) -->
  <section class="mx-auto max-w-7xl px-6 py-20 lg:px-10">
    <div class="flex flex-col items-start gap-4 sm:flex-row sm:items-end sm:justify-between" data-reveal="fade-up">
      <div>
        <p class="text-sm font-semibold text-ink">Lo que dicen de nosotros</p>
        <h2 class="mt-1 text-3xl font-extrabold text-ink sm:text-4xl">FADE en los medios</h2>
      </div>
      <a href="/medios" class="btn shrink-0 max-sm:w-full">Conocer más</a>
    </div>
    <div class="mt-8 overflow-hidden rounded-xl" data-reveal="fade-scale" data-reveal-delay="100">
      <Image
        src={testimonialsImg}
        alt="FADE en los medios"
        widths={[768, 1280, 1600]}
        sizes="100vw"
        format="webp"
        loading="lazy"
        class="h-[320px] w-full object-cover grayscale"
      />
    </div>
  </section>

  <!-- Clientes (carousel) -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-10" data-reveal="fade-up">
      <h2 class="text-3xl font-extrabold text-ink">Nuestros clientes</h2>
      <p class="mt-3 max-w-2xl text-body">
        Empresas que confiaron en nosotros para sus proyectos de instalaciones.
      </p>
    </div>

    <div class="marquee mt-12 space-y-8 overflow-hidden">
      <!-- Fila superior: derecha → izquierda -->
      <div class="marquee-track marquee-left">
        {[...rowTop, ...rowTop].map((c) => (
          <div class="mx-10 flex h-28 w-56 shrink-0 items-center justify-center">
            <img src={encodeURI(c)} alt="" class="max-h-24 max-w-full object-contain grayscale opacity-70 transition hover:opacity-100" loading="lazy" />
          </div>
        ))}
      </div>
      <!-- Fila inferior: izquierda → derecha -->
      <div class="marquee-track marquee-right">
        {[...rowBottom, ...rowBottom].map((c) => (
          <div class="mx-10 flex h-28 w-56 shrink-0 items-center justify-center">
            <img src={encodeURI(c)} alt="" class="max-h-24 max-w-full object-contain grayscale opacity-70 transition hover:opacity-100" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <ContactCta />
</Layout>
