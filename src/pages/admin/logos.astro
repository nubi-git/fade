---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { db } from "../../lib/db";
import { logos } from "../../lib/db/schema";
import { eq, asc } from "drizzle-orm";
import { newId } from "../../lib/auth";
import { saveUpload, deleteUpload } from "../../lib/uploads";

let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("_action");

  if (action === "delLogo") {
    const id = String(form.get("id") ?? "");
    if (id) {
      const row = (await db.select().from(logos).where(eq(logos.id, id)).limit(1))[0];
      if (row) {
        await db.delete(logos).where(eq(logos.id, id));
        await deleteUpload(row.imageUrl);
      }
    }
    return Astro.redirect("/admin/logos");
  }

  if (action === "addLogos") {
    const kind = form.get("kind") === "proveedor" ? "proveedor" : "cliente";
    const files = form.getAll("images");
    const current = (await db.select().from(logos).where(eq(logos.kind, kind))).length;
    let i = 0;
    try {
      for (const f of files) {
        const url = await saveUpload(f, { maxWidth: 500, quality: 90 });
        if (!url) continue;
        await db.insert(logos).values({
          id: newId(),
          kind,
          name: f && typeof f !== "string" ? f.name.replace(/\.[^.]+$/, "") : null,
          imageUrl: url,
          sortOrder: current + i,
        });
        i++;
      }
    } catch (e) {
      error = e instanceof Error ? e.message : "No se pudieron subir los logos.";
    }
    if (!error) return Astro.redirect("/admin/logos");
  }
}

const all = await db.select().from(logos).orderBy(asc(logos.sortOrder), asc(logos.createdAt));
const groups = [
  { kind: "cliente" as const, title: "Clientes", items: all.filter((l) => l.kind === "cliente") },
  { kind: "proveedor" as const, title: "Proveedores", items: all.filter((l) => l.kind === "proveedor") },
];
---

<AdminLayout title="Logos">
  <h1 class="text-3xl font-extrabold text-ink">Logos</h1>
  <p class="mt-2 text-body">Clientes y proveedores que se muestran en los carruseles de la web.</p>

  {error && (
    <p class="mt-6 max-w-4xl rounded-md bg-red-50 px-3 py-2 text-sm font-medium text-red-700" role="alert">{error}</p>
  )}

  {groups.map((g) => (
    <section class="mt-10">
      <div class="flex items-center justify-between">
        <h2 class="text-xl font-bold text-ink">{g.title} <span class="text-sm font-normal text-muted">({g.items.length})</span></h2>
      </div>

      {g.items.length > 0 ? (
        <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-4 lg:grid-cols-6">
          {g.items.map((logo) => (
            <div class="group relative flex h-24 items-center justify-center rounded-lg border border-line bg-white p-3">
              <img src={encodeURI(logo.imageUrl)} alt={logo.name ?? ""} class="max-h-full max-w-full object-contain" loading="lazy" />
              <form method="POST" class="absolute right-1.5 top-1.5">
                <input type="hidden" name="_action" value="delLogo" />
                <input type="hidden" name="id" value={logo.id} />
                <button
                  type="submit"
                  class="rounded-md bg-red-600/90 px-2 py-0.5 text-xs font-semibold text-white opacity-0 transition hover:bg-red-700 group-hover:opacity-100"
                  data-confirm="Se eliminará este logo."
                  data-confirm-title="Eliminar logo"
                >
                  ✕
                </button>
              </form>
            </div>
          ))}
        </div>
      ) : (
        <p class="mt-4 rounded-lg border border-dashed border-line py-8 text-center text-sm text-muted">
          Todavía no hay logos de {g.title.toLowerCase()}.
        </p>
      )}

      <form method="POST" enctype="multipart/form-data" class="mt-4 flex flex-wrap items-center gap-3 rounded-xl border border-dashed border-line p-4">
        <p class="w-full text-xs text-muted">
          Recomendado: PNG con fondo transparente. Se convierte a WebP y se ajusta a ~500px de ancho automáticamente. Ideal ~500×250px.
        </p>
        <input type="hidden" name="_action" value="addLogos" />
        <input type="hidden" name="kind" value={g.kind} />
        <input type="file" name="images" accept="image/*" multiple class="block cursor-pointer text-sm text-body file:mr-3 file:cursor-pointer file:rounded-md file:border-0 file:bg-brand file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white" />
        <button type="submit" class="rounded-md bg-accent px-5 py-2 text-sm font-semibold text-white transition-colors hover:bg-accent-hover">
          Subir {g.title.toLowerCase()}
        </button>
      </form>
    </section>
  ))}
</AdminLayout>
