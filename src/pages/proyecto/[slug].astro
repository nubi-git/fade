---
import Layout from "../../layouts/Layout.astro";
import ContactCta from "../../components/ContactCta.astro";
import { db } from "../../lib/db";
import { projects, projectImages } from "../../lib/db/schema";
import { eq, and, asc, desc } from "drizzle-orm";

const { slug } = Astro.params;
const project = (
  await db
    .select()
    .from(projects)
    .where(and(eq(projects.slug, slug!), eq(projects.published, true)))
    .limit(1)
)[0];

if (!project) return Astro.redirect("/proyectos");

// Galería (fallback a la portada si no hay imágenes cargadas)
const gallery = await db
  .select()
  .from(projectImages)
  .where(eq(projectImages.projectId, project.id))
  .orderBy(asc(projectImages.sortOrder));

const media =
  gallery.length > 0
    ? gallery.map((g) => ({ url: g.url, kind: g.kind }))
    : project.coverImage
      ? [{ url: project.coverImage, kind: "image" as const }]
      : [];

// Navegación entre proyectos (mismo orden que la lista pública)
const ordered = await db
  .select({ slug: projects.slug })
  .from(projects)
  .where(eq(projects.published, true))
  .orderBy(desc(projects.sortOrder), desc(projects.createdAt));
const idx = ordered.findIndex((p) => p.slug === project.slug);
const prev = idx > 0 ? ordered[idx - 1] : null;
const next = idx >= 0 && idx < ordered.length - 1 ? ordered[idx + 1] : null;

const ficha = [
  ["Año de Ejecución", project.year],
  ["Ubicación", project.location],
  ["Comitente", project.client],
  ["Dirección de obra", project.direction],
].filter(([, v]) => v);
---

<Layout title={`${project.name} — FADE Ingeniería`}>
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 sm:py-16 lg:px-10">
    <div class="grid gap-8 lg:grid-cols-2 lg:gap-12">
      <!-- Carrusel -->
      <div data-reveal="fade-scale">
        {media.length > 0 ? (
          <div id="carousel" class="select-none">
            <div class="overflow-hidden rounded-xl">
              <div class="carousel-track flex transition-transform duration-500 ease-out">
                {media.map((m) => (
                  <div class="w-full shrink-0">
                    {m.kind === "video" ? (
                      <video src={m.url} controls class="aspect-[4/3] w-full bg-black object-cover"></video>
                    ) : (
                      <img src={m.url} alt={project.name} data-full={m.url} class="aspect-[4/3] w-full cursor-zoom-in object-cover" />
                    )}
                  </div>
                ))}
              </div>
            </div>

            {media.length > 1 && (
              <div class="mt-5 flex flex-wrap items-center justify-center gap-2 sm:gap-3">
                <button data-prev aria-label="Anterior" class="inline-flex h-9 w-9 items-center justify-center rounded-full text-ink transition-colors hover:bg-surface">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                {media.map((_, i) => (
                  <button
                    data-dot={i}
                    class:list={[
                      "inline-flex h-8 w-8 items-center justify-center rounded-full border text-sm font-semibold transition-colors",
                      i === 0 ? "border-brand bg-brand/10 text-brand" : "border-line text-body hover:border-brand",
                    ]}
                  >
                    {i + 1}
                  </button>
                ))}
                <button data-next aria-label="Siguiente" class="inline-flex h-9 w-9 items-center justify-center rounded-full text-ink transition-colors hover:bg-surface">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
              </div>
            )}
          </div>
        ) : (
          <div class="aspect-[4/3] rounded-xl bg-gradient-to-br from-brand/20 to-brand-light/20"></div>
        )}
      </div>

      <!-- Datos -->
      <div data-reveal="fade-up" data-reveal-delay="120">
        <h1 class="text-3xl font-extrabold text-ink sm:text-4xl">{project.name}</h1>
        {project.summary && <p class="mt-3 text-body">{project.summary}</p>}

        <dl class="mt-8 space-y-6">
          {ficha.map(([k, v]) => (
            <div>
              <dt class="text-base font-bold text-ink">{k}</dt>
              <dd class="mt-1 text-body">{v}</dd>
            </div>
          ))}
          {project.description && (
            <div>
              <dt class="text-base font-bold text-ink">Desarrollo realizado</dt>
              <dd class="mt-1 whitespace-pre-line text-body">{project.description}</dd>
            </div>
          )}
        </dl>
      </div>
    </div>

    <!-- Navegación entre proyectos -->
    <div class="mt-14 flex items-center justify-between border-t border-line pt-8">
      {prev ? (
        <a href={`/proyecto/${prev.slug}`} class="inline-flex items-center gap-3 text-sm font-semibold text-ink hover:text-brand">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span class="rounded-full border border-line px-5 py-2">Anterior</span>
        </a>
      ) : <span></span>}
      {next ? (
        <a href={`/proyecto/${next.slug}`} class="inline-flex items-center gap-3 text-sm font-semibold text-ink hover:text-brand">
          <span class="rounded-full border border-line px-5 py-2">Siguiente</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      ) : <span></span>}
    </div>
  </section>

  <ContactCta />

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 p-6">
    <button id="lightbox-close" aria-label="Cerrar" class="absolute right-5 top-5 text-3xl font-light text-white/80 hover:text-white">&times;</button>
    <img id="lightbox-img" src="" alt="" class="max-h-[90vh] max-w-[92vw] rounded object-contain" />
  </div>
</Layout>

<script>
  const root = document.getElementById("carousel");
  if (root) {
    const track = root.querySelector<HTMLElement>(".carousel-track")!;
    const total = track.children.length;
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-dot]"));
    let cur = 0;

    function show(n: number) {
      cur = (n + total) % total;
      track.style.transform = `translateX(-${cur * 100}%)`;
      dots.forEach((d, i) => {
        const active = i === cur;
        d.classList.toggle("border-brand", active);
        d.classList.toggle("bg-brand/10", active);
        d.classList.toggle("text-brand", active);
        d.classList.toggle("border-line", !active);
        d.classList.toggle("text-body", !active);
      });
    }

    root.querySelector("[data-prev]")?.addEventListener("click", () => show(cur - 1));
    root.querySelector("[data-next]")?.addEventListener("click", () => show(cur + 1));
    dots.forEach((d, i) => d.addEventListener("click", () => show(i)));
  }

  // Lightbox
  const lb = document.getElementById("lightbox");
  const lbImg = document.getElementById("lightbox-img") as HTMLImageElement | null;
  function openLb(src: string) {
    if (!lb || !lbImg) return;
    lbImg.src = src;
    lb.classList.remove("hidden");
    lb.classList.add("flex");
    document.body.style.overflow = "hidden";
  }
  function closeLb() {
    if (!lb) return;
    lb.classList.add("hidden");
    lb.classList.remove("flex");
    document.body.style.overflow = "";
  }
  document.querySelectorAll<HTMLImageElement>("[data-full]").forEach((img) => {
    img.addEventListener("click", () => openLb(img.dataset.full!));
  });
  lb?.addEventListener("click", (e) => {
    if (e.target === lb || (e.target as HTMLElement).id === "lightbox-close") closeLb();
  });
  document.addEventListener("keydown", (e) => e.key === "Escape" && closeLb());
</script>
