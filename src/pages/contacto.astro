---
import Layout from "../layouts/Layout.astro";
import { contactSchema, parseForm, type FieldErrors } from "../lib/validation";
import { getSettings } from "../lib/settings";
import { isMailConfigured, sendContactEmail } from "../lib/mailer";
import { TURNSTILE_SITE_KEY, isTurnstileConfigured, verifyTurnstile } from "../lib/turnstile";
import { getClientIp, rateLimit } from "../lib/security";
import { env } from "../lib/env";

const turnstileOn = isTurnstileConfigured();

let errors: FieldErrors = {};
let sent = false;
const values = { nombre: "", empresa: "", cargo: "", email: "", cod: "", telefono: "", mensaje: "" };

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  for (const k of Object.keys(values) as (keyof typeof values)[]) {
    values[k] = String(form.get(k) ?? "");
  }

  const limited = rateLimit(`contact:${getClientIp(Astro.request)}`, 3, 60_000); // 3 envíos/min

  // Honeypot antispam: si "website" viene relleno, lo ignoramos en silencio.
  if (String(form.get("website") ?? "")) {
    sent = true;
  } else if (!limited.ok) {
    errors._form = `Demasiados envíos. Esperá ${limited.retryAfter} segundos e intentá de nuevo.`;
  } else {
    const parsed = parseForm(contactSchema, form);
    const captcha = await verifyTurnstile(
      String(form.get("cf-turnstile-response") ?? ""),
      Astro.request.headers.get("cf-connecting-ip")
    );
    if (!parsed.success) {
      errors = parsed.errors;
    } else if (!captcha.ok) {
      const codes = captcha.codes?.join(", ");
      errors._form = `No pudimos verificar que no seas un robot. Reintentá la verificación.${codes ? ` [${codes}]` : ""}`;
    } else {
      try {
        const settings = await getSettings().catch(() => ({}) as Record<string, string>);
        const to = settings.contact_email || env.SMTP_FROM || env.SMTP_USER;
        if (!isMailConfigured() || !to) {
          errors._form = "El envío de correo no está configurado. Escribinos directamente por email.";
        } else {
          const cod = String(form.get("cod") ?? "").trim();
          const telefono = [cod, parsed.data.telefono].filter(Boolean).join(" ").trim() || null;
          await sendContactEmail(to, { ...parsed.data, telefono });
          sent = true;
        }
      } catch (e) {
        errors._form = "No pudimos enviar el mensaje. Intentá de nuevo más tarde.";
      }
    }
  }
}

const inputBase =
  "mt-1.5 block w-full min-w-0 rounded-md border border-line px-4 py-2.5 text-sm text-ink placeholder:text-muted outline-none focus:border-brand focus:ring-1 focus:ring-brand aria-[invalid=true]:border-red-500 aria-[invalid=true]:focus:ring-red-500";
const phoneInput =
  "min-w-0 rounded-md border border-line px-4 py-2.5 text-sm text-ink placeholder:text-muted outline-none focus:border-brand focus:ring-1 focus:ring-brand";

// ¿Hubo algún error al enviar? (de campo o general) → para el resumen accesible.
const hasErrors = Object.keys(errors).length > 0;

const office = {
  title: "Nuestra Oficina",
  address: "Montevideo 217, Piso 11 Depto B, Ciudad Autónoma de Buenos Aires.",
  query: "Montevideo 217, Ciudad Autónoma de Buenos Aires, Argentina",
};
const depot = {
  title: "Nuestro Depósito de Materiales",
  address: "Pozo de Vargas 2315, Ing. Pablo Nogues, Malvinas Argentinas - Bs. As.",
  query: "Pozo de Vargas 2315, Ingeniero Pablo Nogués, Malvinas Argentinas, Buenos Aires, Argentina",
};
const mapSrc = (q: string) => `https://www.google.com/maps?q=${encodeURIComponent(q)}&output=embed`;
---

<Layout title="Contacto — FADE Ingeniería">
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-10">
    <!-- Encabezado -->
    <div data-reveal-group data-reveal-stagger="90">
      <h1 class="text-3xl font-extrabold leading-tight text-ink sm:text-5xl">Contacto</h1>
      <p class="mt-3 max-w-xl text-base text-body sm:text-lg">
        Completá el formulario y nuestro equipo se contactará a la brevedad para brindarte
        asesoramiento.
      </p>
    </div>

    <div class="mt-8 grid gap-8 sm:mt-12 lg:grid-cols-2 lg:gap-12">
      <!-- Formulario -->
      {sent ? (
        <div class="min-w-0 rounded-2xl border border-line bg-white p-8 text-center shadow-sm" data-reveal="fade-up">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-green-100 text-green-600">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h2 class="mt-4 text-xl font-bold text-ink">¡Mensaje enviado!</h2>
          <p class="mt-2 text-body">Gracias por escribirnos. Te vamos a responder a la brevedad.</p>
        </div>
      ) : (
        <form method="POST" data-contact class="min-w-0 rounded-2xl border border-line bg-white p-5 shadow-sm sm:p-7" data-reveal="fade-up" novalidate>
          {/* Resumen de errores (accesible: anunciado y enfocable). */}
          <div
            id="form-errors"
            role="alert"
            tabindex="-1"
            class:list={[
              "mb-4 rounded-md bg-red-50 px-3 py-2 text-sm font-medium text-red-700",
              { hidden: !hasErrors },
            ]}
          >
            {errors._form ?? "Revisá los campos marcados e intentá de nuevo."}
          </div>

          <p class="mb-4 text-xs text-muted">Los campos con <span class="text-red-600">*</span> son obligatorios.</p>

          <div class="space-y-4">
            {/* Honeypot antispam (oculto a usuarios) */}
            <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

            <div>
              <label for="f-nombre" class="text-sm font-medium text-ink">
                Nombre completo <span class="text-red-600" aria-hidden="true">*</span>
              </label>
              <input id="f-nombre" type="text" name="nombre" value={values.nombre} required aria-required="true" autocomplete="name" placeholder="Lucas Fernandez" class={inputBase} aria-invalid={errors.nombre ? "true" : undefined} aria-describedby="e-nombre" />
              <p id="e-nombre" class="field-error" role="alert" class:list={{ hidden: !errors.nombre }}>{errors.nombre}</p>
            </div>

            <div>
              <label for="f-empresa" class="text-sm font-medium text-ink">Empresa</label>
              <input id="f-empresa" type="text" name="empresa" value={values.empresa} autocomplete="organization" placeholder="Innovaciones Creativas S.A." class={inputBase} />
            </div>

            <div>
              <label for="f-cargo" class="text-sm font-medium text-ink">Cargo</label>
              <input id="f-cargo" type="text" name="cargo" value={values.cargo} autocomplete="organization-title" placeholder="Manager" class={inputBase} />
            </div>

            <div>
              <label for="f-email" class="text-sm font-medium text-ink">
                Email <span class="text-red-600" aria-hidden="true">*</span>
              </label>
              <input id="f-email" type="email" name="email" value={values.email} required aria-required="true" autocomplete="email" inputmode="email" placeholder="ejemplo@mail.com" class={inputBase} aria-invalid={errors.email ? "true" : undefined} aria-describedby="e-email" />
              <p id="e-email" class="field-error" role="alert" class:list={{ hidden: !errors.email }}>{errors.email}</p>
            </div>

            <div>
              <label for="f-telefono" class="text-sm font-medium text-ink">Teléfono</label>
              <div class="mt-1.5 flex gap-3">
                <input id="f-cod" type="text" name="cod" value={values.cod} inputmode="tel" aria-label="Código de país" placeholder="+ 00" class={`w-20 shrink-0 ${phoneInput}`} />
                <input id="f-telefono" type="tel" name="telefono" value={values.telefono} autocomplete="tel" inputmode="tel" placeholder="00 0000 0000" class={`flex-1 ${phoneInput}`} />
              </div>
            </div>

            <div>
              <label for="f-mensaje" class="text-sm font-medium text-ink">
                Mensaje <span class="text-red-600" aria-hidden="true">*</span>
              </label>
              <textarea id="f-mensaje" name="mensaje" rows="4" required aria-required="true" placeholder="Escriba su mensaje..." class={inputBase} aria-invalid={errors.mensaje ? "true" : undefined} aria-describedby="e-mensaje">{values.mensaje}</textarea>
              <p id="e-mensaje" class="field-error" role="alert" class:list={{ hidden: !errors.mensaje }}>{errors.mensaje}</p>
            </div>

            {turnstileOn && (
              <div>
                <div class="flex justify-center pt-1">
                  <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="light"></div>
                </div>
                <p id="e-turnstile" class="field-error hidden text-center" role="alert"></p>
              </div>
            )}

            <button
              id="contact-submit"
              type="submit"
              class="btn-loading mt-1 w-full rounded-md bg-accent px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-hover disabled:opacity-70"
            >
              Enviar
            </button>
          </div>
        </form>
      )}

      <!-- Datos de contacto + mapas -->
      <div class="min-w-0" data-reveal="fade-up" data-reveal-delay="120">
        <h2 class="text-lg font-bold text-ink">Contactanos por correo o teléfono:</h2>
        <p class="mt-2 break-words text-body">
          Podés escribirnos a
          <a href="mailto:info@fadeingenieria.com.ar" class="font-semibold break-all text-accent hover:underline">info@fadeingenieria.com.ar</a>
          o comunicarte telefónicamente al
          <a href="tel:+541120741602" class="whitespace-nowrap font-semibold text-accent hover:underline">(+54) 11-2074-1602</a>
          y les brindaremos detalles sobre nuestras soluciones
        </p>

        <div class="mt-8 grid gap-6 sm:grid-cols-2">
          {[office, depot].map((loc) => (
            <div class="min-w-0">
              <h3 class="text-sm font-bold text-ink">{loc.title}</h3>
              <div class="mt-3 aspect-[4/3] w-full overflow-hidden rounded-lg border border-line">
                <iframe
                  src={mapSrc(loc.query)}
                  title={loc.title}
                  class="block h-full w-full max-w-full border-0"
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                ></iframe>
              </div>
              <p class="mt-3 text-sm text-body">{loc.address}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {turnstileOn && (
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  )}

  <style>
    /* Spinner de "enviando" en el botón del formulario. */
    button.is-loading { position: relative; color: transparent !important; pointer-events: none; }
    button.is-loading::after {
      content: "";
      position: absolute;
      inset: 0;
      margin: auto;
      width: 1.1rem;
      height: 1.1rem;
      border-radius: 9999px;
      border: 2px solid rgba(255, 255, 255, 0.55);
      border-top-color: #fff;
      animation: contact-spin 0.6s linear infinite;
    }
    @keyframes contact-spin { to { transform: rotate(360deg); } }
  </style>

  <script>
    const form = document.querySelector<HTMLFormElement>("form[data-contact]");
    if (form) {
      const summary = document.getElementById("form-errors");
      const submitBtn = document.getElementById("contact-submit") as HTMLButtonElement | null;
      const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      const rules: Record<string, (v: string) => string> = {
        nombre: (v) => (v.trim() ? "" : "El nombre es obligatorio."),
        email: (v) =>
          !v.trim() ? "El email es obligatorio." : emailRe.test(v.trim()) ? "" : "Ingresá un email válido.",
        mensaje: (v) => (v.trim() ? "" : "El mensaje es obligatorio."),
      };

      const fieldEl = (name: string) => form.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement | null;

      function setError(name: string, msg: string) {
        const input = fieldEl(name);
        const err = document.getElementById("e-" + name);
        if (err) {
          err.textContent = msg;
          err.classList.toggle("hidden", !msg);
        }
        if (input) {
          if (msg) input.setAttribute("aria-invalid", "true");
          else input.removeAttribute("aria-invalid");
        }
      }

      // Limpia el error mientras el usuario corrige el campo.
      Object.keys(rules).forEach((name) => {
        fieldEl(name)?.addEventListener("input", () => setError(name, ""));
      });

      // Código de país: siempre "+" seguido de dígitos (ej. +54).
      const cod = document.getElementById("f-cod") as HTMLInputElement | null;
      cod?.addEventListener("input", () => {
        const digits = cod.value.replace(/\D/g, "");
        cod.value = digits ? "+" + digits : "";
      });
      // Teléfono: solo dígitos, espacios y guiones.
      const tel = document.getElementById("f-telefono") as HTMLInputElement | null;
      tel?.addEventListener("input", () => {
        tel.value = tel.value.replace(/[^\d\s-]/g, "");
      });

      form.addEventListener("submit", (e) => {
        let firstInvalid: HTMLElement | null = null;
        for (const [name, rule] of Object.entries(rules)) {
          const input = fieldEl(name);
          const msg = rule(input?.value ?? "");
          setError(name, msg);
          if (msg && !firstInvalid) firstInvalid = input;
        }

        // Turnstile: si el widget está presente, exige el token antes de enviar.
        let tsError = false;
        if (form.querySelector(".cf-turnstile")) {
          const token = form.querySelector<HTMLInputElement>('[name="cf-turnstile-response"]');
          const tsErrEl = document.getElementById("e-turnstile");
          if (!token || !token.value) {
            tsError = true;
            if (tsErrEl) {
              tsErrEl.textContent = "Completá la verificación anti-robot.";
              tsErrEl.classList.remove("hidden");
            }
          } else tsErrEl?.classList.add("hidden");
        }

        if (firstInvalid || tsError) {
          e.preventDefault();
          if (summary) {
            summary.textContent = "Revisá los campos marcados e intentá de nuevo.";
            summary.classList.remove("hidden");
          }
          (firstInvalid ?? summary)?.focus();
          return;
        }

        // Todo OK → estado "enviando".
        if (submitBtn) {
          submitBtn.classList.add("is-loading");
          submitBtn.disabled = true;
        }
      });

      // Tras recargar con errores del servidor, llevar el foco al primero.
      const serverInvalid = form.querySelector<HTMLElement>('[aria-invalid="true"]');
      if (serverInvalid) serverInvalid.focus();
      else if (summary && !summary.classList.contains("hidden")) summary.focus();
    }
  </script>
</Layout>
