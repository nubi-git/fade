---
import "../styles/global.css";
import ConfirmDialog from "../components/admin/ConfirmDialog.astro";

interface Props {
  title?: string;
}
const { title = "Panel" } = Astro.props;
const user = Astro.locals.user;
const path = Astro.url.pathname;

const nav = [
  { label: "Proyectos", href: "/admin/projects", icon: "folder" },
  { label: "Medios", href: "/admin/media", icon: "doc" },
  { label: "Archivos", href: "/admin/settings", icon: "cog" },
  { label: "Logos", href: "/admin/logos", icon: "image" },
  { label: "Contacto", href: "/admin/contacto", icon: "mail" },
];

const isActive = (href: string) =>
  path === href || (href !== "/admin" && path.startsWith(href));

const icons: Record<string, string> = {
  home: '<path d="M3 11l9-8 9 8M5 10v10h5v-6h4v6h5V10" stroke-linecap="round" stroke-linejoin="round"/>',
  folder: '<path d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" stroke-linecap="round" stroke-linejoin="round"/>',
  doc: '<path d="M7 3h7l5 5v13a1 1 0 01-1 1H7a1 1 0 01-1-1V4a1 1 0 011-1z" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 3v5h5" stroke-linecap="round" stroke-linejoin="round"/>',
  cog: '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 11-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 11-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 11-2.83-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 110-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 114 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 110 4h-.09a1.65 1.65 0 00-1.51 1z" stroke-linecap="round" stroke-linejoin="round"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6" stroke-linecap="round" stroke-linejoin="round"/>',
  image: '<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="1.5"/><path d="M21 15l-5-5L5 21" stroke-linecap="round" stroke-linejoin="round"/>',
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — FADE Admin</title>
  </head>
  <body class="relative min-h-screen text-ink">
    <!-- Fondo del admin: imagen + velo para legibilidad -->
    <div
      class="pointer-events-none fixed inset-0 -z-20 bg-[url('/images/fondos/home_hero_image.png')] bg-cover bg-center"
    ></div>
    <div class="pointer-events-none fixed inset-0 -z-10 bg-surface/80"></div>

    {user && (
      <header class="border-b border-line bg-white">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
          <div class="flex items-center gap-6">
            <a href="/admin" aria-label="FADE Admin">
              <img src="/images/logos/fade/logo_fade.png" alt="FADE" class="h-9 w-auto" />
            </a>
            <!-- Nav desktop -->
            <nav class="hidden gap-4 text-sm md:flex">
              {nav.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    "rounded px-2 py-1 font-medium",
                    isActive(item.href) ? "bg-brand/10 text-brand" : "text-body hover:text-brand",
                  ]}
                >
                  {item.label}
                </a>
              ))}
            </nav>
          </div>
          <div class="flex items-center gap-3 text-sm">
            <span class="hidden text-muted sm:inline">{user.name} ({user.role})</span>
            <form method="POST" action="/admin/logout">
              <button class="font-medium text-accent hover:underline">Salir</button>
            </form>
          </div>
        </div>
      </header>
    )}

    <main class="mx-auto max-w-6xl px-4 py-8 pb-24 sm:px-6 md:py-10 md:pb-10">
      <slot />
    </main>

    {user && (
      <!-- Nav inferior mobile -->
      <nav class="fixed inset-x-0 bottom-0 z-50 border-t border-line bg-white md:hidden">
        <div class="mx-auto flex max-w-6xl">
          {nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                "flex flex-1 flex-col items-center gap-1 py-2.5 text-xs font-medium",
                isActive(item.href) ? "text-brand" : "text-muted",
              ]}
            >
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" set:html={icons[item.icon]} />
              {item.label}
            </a>
          ))}
        </div>
      </nav>
    )}

    {user && <ConfirmDialog />}
  </body>
</html>
