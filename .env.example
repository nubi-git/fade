# Base de datos MySQL (VPS)
DB_HOST=localhost
DB_PORT=3306
DB_USER=fade
DB_PASSWORD=cambia_esto
DB_NAME=fade

# Cookies seguras en producción (https). En local dejar false.
SECURE_COOKIES=false

# SMTP para el formulario de contacto (datos del servidor de correo del hosting/cPanel)
SMTP_HOST=mail.tudominio.com
SMTP_PORT=587
SMTP_USER=info@fadeingenieria.com.ar
SMTP_PASS=cambia_esto
SMTP_FROM=info@fadeingenieria.com.ar

# Cloudflare Turnstile (anti-spam del formulario). Dejar vacío para desactivar.
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
